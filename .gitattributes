# Prevent Windows from converting LF to CRLF in shell scripts and configs
# (CRLF in shell scripts causes /bin/sh: bad interpreter errors in Docker)
*.sh       text eol=lf
*.conf     text eol=lf
Dockerfile text eol=lf
Makefile   text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.json     text eol=lf
*.toml     text eol=lf
*.sql      text eol=lf
*.go       text eol=lf
