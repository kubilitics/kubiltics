FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /demo-app ./cmd/demo-app/

FROM alpine:3.21
RUN apk add --no-cache ca-certificates
COPY --from=builder /demo-app /usr/local/bin/demo-app
EXPOSE 8080
ENTRYPOINT ["demo-app"]
