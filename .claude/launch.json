{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd kubilitics-frontend && npx vite --port 5173 --strictPort"],
      "port": 5173,
