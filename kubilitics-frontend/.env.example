# Kubilitics Frontend Configuration
# Port reference: project-docs/PORTS.md (backend 819, frontend 5173, AI 8081)

# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------

# Port for the frontend dev server (default: 5173; strictPort in vite.config.ts)
# PORT=5173

# Base URL for the Kubilitics Backend API (default: http://localhost:819)
# Use empty string in development to leverage Kite proxy (avoids CORS/WS issues)
# VITE_API_BASE=

# Port of the Kubilitics Backend (used for proxy configuration)
# Default is 819 (desktop sidecar port)
VITE_BACKEND_PORT=819

# -----------------------------------------------------------------------------
# AI & Intelligence
# -----------------------------------------------------------------------------

# URL for the AI Backend (HTTP)
# Default: http://localhost:8081
VITE_AI_BACKEND_URL=http://localhost:8081

# URL for the AI Backend (WebSocket)
# Default: ws://localhost:8081
VITE_AI_WS_URL=ws://localhost:8081

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable Mock Mode for demo/testing without backend
# VITE_MOCK_MODE=false
