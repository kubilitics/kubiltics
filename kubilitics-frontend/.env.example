# Kubilitics Frontend Configuration
# Port reference: project-docs/PORTS.md (backend 8190, frontend 5173, AI 8081)

# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------

# Port for the frontend dev server (default: 5173; strictPort in vite.config.ts)
# PORT=5173

# Base URL for the Kubilitics Backend API (default: http://localhost:8190)
# Use empty string in development to leverage Kite proxy (avoids CORS/WS issues)
# VITE_API_BASE=

# Port of the Kubilitics Backend (used for proxy configuration)
# Default is 8190 (desktop sidecar port)
VITE_BACKEND_PORT=8190

# -----------------------------------------------------------------------------
# AI & Intelligence
# -----------------------------------------------------------------------------

# URL for the AI Backend (HTTP)
# Default: http://localhost:8081
VITE_AI_BACKEND_URL=http://localhost:8081

# URL for the AI Backend (WebSocket)
# Default: ws://localhost:8081
VITE_AI_WS_URL=ws://localhost:8081

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable Mock Mode for demo/testing without backend
# VITE_MOCK_MODE=false

# -----------------------------------------------------------------------------
# Error Tracking & Monitoring
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking (leave empty to disable Sentry)
# When set, errors are sent to Sentry with source maps for readable stack traces.
# When empty, falls back to console-only logging + optional VITE_ERROR_TRACKING_URL.
# VITE_SENTRY_DSN=

# Legacy error tracking endpoint (optional, fires alongside Sentry if both set)
# VITE_ERROR_TRACKING_URL=
